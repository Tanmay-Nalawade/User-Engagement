# Copy to secret.yaml, fill in your Atlas URI, then apply.
# Do NOT commit secret.yaml with real credentials.
apiVersion: v1
kind: Secret
metadata:
  name: user-engagement-secrets
  namespace: user-engagement
type: Opaque
stringData:
  MONGODB_URI: "mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/user-engagement?retryWrites=true&w=majority"
